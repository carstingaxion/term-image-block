<?xml version="1.0"?>
<ruleset name="term-image-block">
	<description>Coding standards for term-image-block</description>

	<file>.</file>
	<arg name="basepath" value="./"/><!-- Strip the file paths down to the relevant bit -->

	<exclude-pattern>*/build/*</exclude-pattern>
	<exclude-pattern>*/vendor/*</exclude-pattern>
	
	<!-- Rules: figuren.theater Coding Standards -->
	<rule ref="figurentheater" />

	<!-- Allow additional text_domains -->
	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="term-image-block"/>
			</property>
		</properties>
	</rule>
	<rule ref="WordPress.NamingConventions.PrefixAllGlobals">
		<properties>
			<property name="prefixes" type="array">
				<element value="__NAMESPACE__"/>
				<element value="Carstingaxion_Term_Image"/>
			</property>

		</properties>
	</rule> 
	<rule ref="WordPress">
		<exclude name="WordPress.Files.FileName.InvalidClassFileName" />
	</rule>
	<rule ref="Universal">
		<exclude name="Universal.Lists.DisallowShortListSyntax"/>
		<exclude name="Universal.Namespaces.EnforceCurlyBraceSyntax.Forbidden" />
		<exclude name="Universal.PHP.RequireExitDieParentheses.Missing" />
		<exclude name="Universal.Classes.RequireFinalClass.NonFinalClassFound" />
	</rule>
</ruleset>
