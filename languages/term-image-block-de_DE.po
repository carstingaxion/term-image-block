msgstr "Wird aus aktuellem Beitrag oder Archiv aufgelöst"

#: build/index.js:4 src/edit.js:256
msgid "Uses queried term on archive pages"
msgstr "Verwendet den abgefragten Term auf Archivseiten"

#: build/index.js:4 src/edit.js:285
msgid "No image set"
msgstr "Kein Bild festgelegt"

#: build/index.js:4 src/edit.js:292
msgid "Use the Term Image panel to upload one"
msgstr "Verwende das Term-Bild-Panel, um eines hochzuladen"

#: build/index.js:4 src/edit.js:297
msgid "Receiving term from parent block context"
msgstr "Term wird aus dem übergeordneten Block-Kontext bezogen"

#: build/index.js:4 src/edit.js:302
msgid "Select a taxonomy and term in the sidebar"
msgstr "Wähle eine Taxonomie und einen Term in der Seitenleiste"

#: build/index.js:4 src/edit.js:342
msgid "Clear selection"
msgstr "Auswahl aufheben"

