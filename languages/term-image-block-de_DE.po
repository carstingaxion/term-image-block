msgstr "Bildunterschrift anzeigen"

#: build/index.js:1 src/components/display-settings-panel.js:79
msgid "Custom caption"
msgstr "Eigene Bildunterschrift"

#: build/index.js:1 src/components/display-settings-panel.js:85
msgid "Leave empty to use term name"
msgstr "Leer lassen, um den Term-Namen zu verwenden"

#: build/index.js:1 src/components/term-selection-panel.js:47
msgid "Select a taxonomy"
msgstr "Taxonomie auswählen"

#: build/index.js:1 src/components/term-selection-panel.js:53
msgid "Select a term"
msgstr "Term auswählen"

#: build/index.js:1 src/components/term-selection-panel.js:58
msgid "Term Selection"
msgstr "Term-Auswahl"

#: build/index.js:1 src/components/fse-inspector.js:59
#: src/components/term-selection-panel.js:62
msgid "Taxonomy"
msgstr "Taxonomie"

#: build/index.js:1 src/components/term-selection-panel.js:69
msgid "Choose a taxonomy to select terms from"
msgstr "Wähle eine Taxonomie, aus der Terms ausgewählt werden sollen"

#: build/index.js:1 src/components/term-selection-panel.js:80
msgid "Term"
msgstr "Term"

#: build/index.js:1 src/components/term-selection-panel.js:89
msgid "Leave empty to auto-detect on archive pages"
msgstr "Leer lassen, um auf Archivseiten automatisch zu erkennen"

#: build/index.js:1 build/index.js:3 build/index.js:4
#: src/components/term-image-panel.js:46 src/edit.js:163 src/edit.js:222
#: src/edit.js:286
msgid "Term Image"
msgstr "Term-Bild"

#: build/index.js:1 src/components/term-image-panel.js:83
msgid "Replace Image"
msgstr "Bild ersetzen"

#: build/index.js:1 src/components/term-image-panel.js:95
msgid "Remove Image"
msgstr "Bild entfernen"

#: build/index.js:1 src/components/term-image-panel.js:109
msgid "Upload Image"
msgstr "Bild hochladen"

#: build/index.js:1 src/components/term-image-panel.js:122
msgid ""
"This image will be saved to the term and available for use throughout your "
"site."
msgstr ""
"Dieses Bild wird beim Term gespeichert und kann überall auf deiner Website "
"verwendet werden."

#: build/index.js:1 src/components/fse-inspector.js:44
msgid "Auto-detect (archive pages)"
msgstr "Automatisch erkennen (Archivseiten)"

#: build/index.js:1 src/components/fse-inspector.js:50
msgid "Term Detection"
msgstr "Term-Erkennung"

#: build/index.js:1 src/components/fse-inspector.js:67
msgid ""
"The block will use the first term from this taxonomy assigned to the current "
"post, or the queried term on archive pages."
msgstr ""
"Der Block verwendet den ersten Term dieser Taxonomie, der dem aktuellen "
"Beitrag zugewiesen ist, oder den abgefragten Term auf Archivseiten."

#: build/index.js:1 src/components/fse-inspector.js:71
msgid "Auto-detect uses the queried term on taxonomy archive pages."
msgstr ""
"Die automatische Erkennung verwendet den abgefragten Term auf Taxonomie-"
"Archivseiten."

#: build/index.js:1 src/components/standard-inspector.js:76
msgid ""
"Term data is provided by a parent block. Set taxonomy and term manually to "
"override."
msgstr ""
"Die Term-Daten werden von einem übergeordneten Block bereitgestellt. "
"Taxonomie und Term manuell festlegen, um dies zu überschreiben."

#: build/index.js:1 src/hooks/use-term-image-manager.js:85
msgid "Term image updated successfully!"
msgstr "Term-Bild erfolgreich aktualisiert!"

#: build/index.js:1 src/hooks/use-term-image-manager.js:89
msgid "Term image removed successfully!"
msgstr "Term-Bild erfolgreich entfernt!"

#: build/index.js:1 src/hooks/use-term-image-manager.js:99
msgid "Failed to update term image"
msgstr "Term-Bild konnte nicht aktualisiert werden"

